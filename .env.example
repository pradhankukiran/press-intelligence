APP_ENV=development
DATA_MODE=mock
LOG_LEVEL=INFO
LOG_FORMAT=console

GUARDIAN_API_KEY=
GUARDIAN_BASE_URL=https://content.guardianapis.com

GOOGLE_CLOUD_PROJECT=
# Path used both locally and inside docker-compose (secrets/ is mounted at /app/secrets).
# For local (non-docker) runs, set this to the absolute host path instead.
GOOGLE_APPLICATION_CREDENTIALS=/app/secrets/service-account.json
BIGQUERY_LOCATION=US
BIGQUERY_DATASET_RAW=raw_guardian
BIGQUERY_DATASET_ANALYTICS=analytics
BIGQUERY_DATASET_OPS=ops

AIRFLOW_BASE_URL=http://airflow-webserver:8080/api/v1
AIRFLOW_USERNAME=airflow
AIRFLOW_PASSWORD=airflow
AIRFLOW_RECENT_DAG_ID=guardian_ingest_recent
AIRFLOW_BACKFILL_DAG_ID=guardian_backfill_range
AIRFLOW_TIMEOUT_SECONDS=15.0
AIRFLOW_HEALTH_TIMEOUT_SECONDS=3.0

DEFAULT_WINDOW_DAYS=12
MOCK_SEED_DATE=2026-03-12

QUALITY_MISSING_SECTION_THRESHOLD=0
QUALITY_MISSING_PUBLISHED_AT_THRESHOLD=0

ALERTS_WEBHOOK_URL=
ALERTS_WEBHOOK_TIMEOUT_SECONDS=5.0

NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
